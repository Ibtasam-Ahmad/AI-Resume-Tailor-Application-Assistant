# ─────────────────────────────────────────────────────────────────────────────
# Configure a key for ANY ONE provider — the app auto-detects which provider is
# present and uses it. If you configure more than one, you can switch between
# them in the sidebar. Each provider supports multiple keys with auto-failover
# (add _1, _2, _3 … or a comma-separated PLURAL form).
# ─────────────────────────────────────────────────────────────────────────────

# ── Groq ─────────────────────────────────────────────────────────────────────
# GROQ_API_KEY_1 = "gsk_your_first_key_here"
# GROQ_API_KEY_2 = "gsk_your_second_key_here"
# GROQ_API_KEY   = "gsk_single_key_here"
# GROQ_API_KEYS  = "gsk_key1,gsk_key2,gsk_key3"

# ── OpenAI ───────────────────────────────────────────────────────────────────
# OPENAI_API_KEY = "sk-..."
# OPENAI_API_KEY_1 = "sk-..."

# ── OpenRouter ───────────────────────────────────────────────────────────────
# OPENROUTER_API_KEY = "sk-or-..."

# ── NVIDIA NIM ───────────────────────────────────────────────────────────────
# NVIDIA_API_KEY = "nvapi-..."

# ── Google Gemini ────────────────────────────────────────────────────────────
# GEMINI_API_KEY = "AIza..."
